            <property name="styleSheet">
             <string notr="true">/* Le da el color naranja corporativo al botón principal */
QPushButton#btnSeleccionarUsuario {
    background-color: #FF8C00;
    color: white;
    border-radius: 8px; /* Redondea los bordes */
    padding: 10px;
    font-weight: bold;
    font-size: 14px;
}

/* Efecto para cuando el usuario pase el dedo/ratón por encima */
QPushButton#btnSeleccionarUsuario:hover {
    background-color: #E67E22;
}</string>
